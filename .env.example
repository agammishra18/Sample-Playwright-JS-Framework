# Copy to `.env` and fill in values. Never commit the real .env.

# qa | stage | prod
TEST_ENV=qa

# UI credentials used by login tests (public demo site: saucedemo.com)
UI_USERNAME=standard_user
UI_PASSWORD=secret_sauce

# API auth (reqres.in requires a dummy api-key on writes)
API_TOKEN=reqres-free-v1

# Optional: set DEBUG=1 to enable debug-level logs from utils/logger.ts
DEBUG=
